{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "alumnos.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.+\\.[jcw]s|json|css)$", "dest": "/$1" },
    { "src": "/(.*)$", "dest": "/index.html" }
  ]
}
